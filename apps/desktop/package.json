{
  "name": "@airgap/desktop",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "dist/main.cjs",
  "scripts": {
    "build": "tsup src/main.ts --format cjs --platform node --target node22 --out-dir dist --clean --external electron",
    "start": "npm run build && electron .",
    "test": "vitest run --config vitest.config.ts",
    "package": "npm run build && electron-forge package --arch=arm64",
    "make": "npm run build && electron-forge make --arch=arm64"
  },
  "devDependencies": {
    "@electron-forge/cli": "8.0.0-alpha.10",
    "@electron-forge/maker-dmg": "8.0.0-alpha.10",
    "@electron-forge/maker-zip": "8.0.0-alpha.10",
    "electron": "43.1.0"
  }
}
