{
  "name": "airgap",
  "version": "0.2.0",
  "description": "Scan, redact, and carry your local AI coding sessions. No cloud, no accounts.",
  "keywords": [
    "claude-code",
    "codex",
    "session",
    "secrets",
    "redaction",
    "handoff"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kylvia/airgap.git"
  },
  "homepage": "https://github.com/kylvia/airgap#readme",
  "bugs": {
    "url": "https://github.com/kylvia/airgap/issues"
  },
  "type": "module",
  "bin": {
    "airgap": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "tsup": {
    "entry": [
      "src/index.ts"
    ],
    "format": [
      "esm"
    ],
    "clean": true,
    "banner": {
      "js": "#!/usr/bin/env node"
    }
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@mdit/plugin-tasklist": "^1.0.1",
    "commander": "^13.1.0",
    "markdown-it": "^14.3.0",
    "picocolors": "^1.1.1",
    "yauzl": "^3.2.0",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^22.15.0",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^2.4.6",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
